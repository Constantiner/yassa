{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": false,
		"isolatedDeclarations": true,
		"emitDeclarationOnly": false,
		"outDir": "./dist",
		"rootDir": "./src",
		"allowJs": false,
		"checkJs": false,
		"verbatimModuleSyntax": true,
		"stripInternal": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/*.test.ts", "coverage", "dist", "node_modules"]
}
